{
  "manifest_version": 3,
  "name": "KINSY — cute agent for Kintara",
  "short_name": "KINSY",
  "version": "0.1.0",
  "description": "A little companion farming $KINS for you. Phantom sign-in, live resources, and scoped sessions.",
  "homepage_url": "https://kinsy.fun",
  "author": "KINSY",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "KINSY",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://kintara.com/*", "https://*.kintara.com/*", "https://kintara.gg/*", "https://*.kintara.gg/*"],
      "js":  ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://kintara.com/*", "https://*.kintara.com/*", "https://kintara.gg/*", "https://*.kintara.gg/*"],
      "js": ["content/ws-bridge.js", "content/phantom-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],

  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "notifications"
  ],

  "host_permissions": [
    "https://kintara.com/*",
    "https://*.kintara.com/*",
    "https://kintara.gg/*",
    "https://*.kintara.gg/*",
    "https://api.kinsai.xyz/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://kintara.com/*", "https://*.kintara.com/*", "https://kintara.gg/*", "https://*.kintara.gg/*"]
    }
  ]
}
